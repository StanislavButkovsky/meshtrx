<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#141414">

    <!-- Фильтр -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="#111111">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/filter"
            android:textColor="#888888"
            android:textSize="13sp" />

        <Spinner android:id="@+id/spinnerFilter"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="#1a1a1a"
            android:popupBackground="#1a1a1a" />
    </LinearLayout>

    <!-- Список сообщений -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- Адресат + ввод -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#111111">

        <TextView android:id="@+id/tvDest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/to_all"
            android:textColor="#4a9eff"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton android:id="@+id/btnDest"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_at"
                android:background="@drawable/btn_blue"
                android:scaleType="centerInside"
                android:contentDescription="@string/callsign"
                android:enabled="false" />

            <EditText android:id="@+id/etMessage"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="@string/msg_hint"
                android:textColor="#e8e8e8"
                android:textColorHint="#555555"
                android:background="#1a1a1a"
                android:paddingHorizontal="8dp"
                android:maxLength="84"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginHorizontal="4dp" />

            <ImageButton android:id="@+id/btnSend"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_send"
                android:background="@drawable/btn_green"
                android:scaleType="centerInside"
                android:contentDescription="@string/send"
                android:enabled="false" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
